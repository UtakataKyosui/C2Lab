{
  "description": "vibe-kanban タスク管理フック。セッション開始時にvibe-kanbanの状態をチェックし、セッション終了時にタスク更新を促す。",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ensure-server.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-stop.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
