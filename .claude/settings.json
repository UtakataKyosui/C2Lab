{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "WebFetch(domain:docs.jj-vcs.dev)",
      "Bash(docker run:*)"
    ],
    "deny": [
      "Bash(git:*)"
    ]
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true,
    "plugin-dev@claude-code-plugins": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/pre-commit-lint.py"
          }
        ]
      }
    ]
  }
}
